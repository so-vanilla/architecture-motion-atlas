{
  "name": "architecture-motion-atlas",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "packageManager": "npm@11.12.1",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "lint": "eslint .",
    "test": "vitest run",
    "check:content": "tsx scripts/check-content.ts",
    "check:diagrams": "tsx scripts/check-diagrams.ts",
    "check:routes": "tsx scripts/check-routes.ts",
    "check:responsive": "tsx scripts/check-responsive.ts",
    "check": "npm run lint && npm run test && npm run check:content && npm run check:diagrams && npm run check:routes && npm run check:responsive && npm run build"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.1.2",
    "vite": "^7.3.1",
    "typescript": "^5.9.3",
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/node": "^25.0.3",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.2",
    "tsx": "^4.21.0",
    "typescript-eslint": "^8.50.0",
    "vitest": "^4.0.16"
  }
}
